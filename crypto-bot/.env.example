# Crypto Trading Bot — Environment Configuration
# Copy this to .env and fill in your credentials
# .env is NEVER committed to git

# ============================================
# X (Twitter) API — Sentiment Scoring
# ============================================
X_BEARER_TOKEN=your_bearer_token_here

# ============================================
# Coinbase Advanced Trade API — Trading Execution
# ============================================
COINBASE_API_KEY_ID=your_key_id_here           # Key ID (UUID format)
COINBASE_PRIVATE_KEY=your_private_key_here     # Private Key (PEM format)
COINBASE_ORGANIZATION_ID=your_org_id_here      # Organization ID (optional, for multi-org accounts)
COINBASE_SANDBOX=true                          # Set to false for production (after security audit)

# ============================================
# Database — Local SQLite (can migrate to PostgreSQL on VPS)
# ============================================
DATABASE_URL=sqlite:///./trading.db
DATABASE_ECHO=false            # Set to true for SQL debugging

# ============================================
# Trading Parameters
# ============================================
INITIAL_CAPITAL=1000           # USD, will be overridden by --capital flag
RISK_PER_TRADE=0.02            # 2% per trade
TARGET_RSI_HIGH=70             # Overbought threshold (sell signal)
TARGET_RSI_LOW=30              # Oversold threshold (buy signal)
RSI_PERIOD=14                  # Standard RSI lookback

# ============================================
# Sentiment Thresholds
# ============================================
SENTIMENT_BUY_THRESHOLD=0.5    # Positive sentiment score to trigger buy
SENTIMENT_SELL_THRESHOLD=-0.5  # Negative sentiment score to trigger sell
SENTIMENT_WEIGHT=0.3           # 30% of signal = sentiment, 70% = RSI

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/trading.log
LOG_MAX_SIZE_MB=50             # Rotate when file hits 50MB
LOG_BACKUP_COUNT=5             # Keep 5 old log files

# ============================================
# Environment
# ============================================
ENVIRONMENT=development        # development, production
DEBUG=false                    # Extra logging in dev mode

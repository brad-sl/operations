# Crypto Trading Bot Configuration

# Coinbase API Credentials (Optional)
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=

# X (Twitter) API Configuration
X_BEARER_TOKEN=your_bearer_token_here

# Trading Configuration
TRADING_CAPITAL=1000
RISK_SL_PCT=2.0
RISK_TP_PCT=5.0

# Pairs and Trading Parameters
PAIRS=BTC-USD,XRP-USD,ETH-USD,DOGE-USD,ADA-USD,SOL-USD
CYCLE_INTERVAL=1800  # 30-minute cycles
VARIANT=5  # Current trading strategy variant

# Logging and Monitoring
LOG_LEVEL=INFO
PROMETHEUS_METRICS_PORT=8502

# Sentiment Sources Configuration
SENTIMENT_SOURCES=x_api,reddit,news_api
SENTIMENT_WEIGHT=0.4